# PostgreSQL credentials (used by docker-compose and DATABASE_URL)
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=finapp

# Database URL - use PostgreSQL for production
DATABASE_URL=postgresql://user:password@localhost:5432/finapp

# JWT Secret for authentication
JWT_SECRET=your-secret-key-here

# OpenAI API Key for AI features
OPENAI_API_KEY=sk-your-openai-api-key

# Logfire token for observability (optional)
LOGFIRE_TOKEN=your-logfire-token
